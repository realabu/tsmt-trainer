    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma generate && prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
